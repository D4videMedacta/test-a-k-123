      <li>Gradient logo on white or cream backgrounds only</li>
      <li>White logo on navy, dark, or photo backgrounds</li>
      <li>Minimum height: 32px digital / 10mm print</li>
      <li>Never recolor, rotate, stretch, or add effects</li>
      <li>Clear space: equal to the height of the "A" letterform on all sides</li>
    </ul>
  </div>
</section>

<!-- IMAGERY -->
<section class="ds-section" id="imagery">
  <div class="ds-lbl"><div class="ds-lbl-line"></div><span class="ds-lbl-text">Guidelines</span></div>
  <h2 class="ds-h">Imagery Rules</h2>
  <div class="g3" style="margin-top:4px;">
    <div style="padding:20px;background:white;border:1px solid var(--border);border-radius:14px;border-top:3px solid var(--teal);">
      <div style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--teal);margin-bottom:10px;">Subject</div>
      <ul style="font-size:13px;color:var(--muted);padding-left:16px;line-height:2.2;"><li>Patients 55–70 years old</li><li>Mixed US ethnicity</li><li>Active, outdoor settings</li><li>Post-recovery — hiking, golf, family</li><li>Real people, not obvious models</li></ul>
    </div>
    <div style="padding:20px;background:white;border:1px solid var(--border);border-radius:14px;border-top:3px solid var(--teal);">
      <div style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--teal);margin-bottom:10px;">Style</div>
      <ul style="font-size:13px;color:var(--muted);padding-left:16px;line-height:2.2;"><li>Natural light, warm tones</li><li>Candid, not staged</li><li>High resolution, sharp focus</li><li>Outdoor or neutral backgrounds</li><li>Positive, serene expression</li></ul>
    </div>
    <div style="padding:20px;background:white;border:1px solid var(--border);border-radius:14px;border-top:3px solid #E24B4A;">
      <div style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#E24B4A;margin-bottom:10px;">Avoid</div>
      <ul style="font-size:13px;color:var(--muted);padding-left:16px;line-height:2.2;"><li>Hospital rooms, grey/green bg</li><li>Surgeon with mask &amp; gloves</li><li>X-rays, anatomy diagrams</li><li>Obvious stock photo lighting</li><li>Plastic smiles, perfume-ad look</li></ul>
    </div>
  </div>
</section>

<!-- VOICE & TONE -->
<section class="ds-section" id="voice">
  <div class="ds-lbl"><div class="ds-lbl-line"></div><span class="ds-lbl-text">Guidelines</span></div>
  <h2 class="ds-h">Voice & Tone</h2>
  <div class="g3" style="margin-top:4px;">
    <div style="padding:24px;background:white;border:1px solid var(--border);border-radius:14px;border-left:3px solid var(--navy);"><div style="font-size:13px;font-weight:700;color:var(--navy);margin-bottom:8px;">Competent</div><div style="font-size:13px;color:var(--muted);line-height:1.7;">Speak with clinical authority. Never oversimplify. Patients research — they deserve accurate language.</div></div>
    <div style="padding:24px;background:white;border:1px solid var(--border);border-radius:14px;border-left:3px solid var(--teal);"><div style="font-size:13px;font-weight:700;color:var(--navy);margin-bottom:8px;">Empathetic</div><div style="font-size:13px;color:var(--muted);line-height:1.7;">Acknowledge pain and anxiety. Lead with outcomes, not procedures. The patient is the hero.</div></div>
    <div style="padding:24px;background:white;border:1px solid var(--border);border-radius:14px;border-left:3px solid var(--teal);"><div style="font-size:13px;font-weight:700;color:var(--navy);margin-bottom:8px;">Direct</div><div style="font-size:13px;color:var(--muted);line-height:1.7;">Short sentences. Active voice. Tell the patient what happens next. No jargon without explanation.</div></div>
  </div>
</section>

<!-- DO / DON'T -->
<section class="ds-section" id="do-dont">
  <div class="ds-lbl"><div class="ds-lbl-line"></div><span class="ds-lbl-text">Guidelines</span></div>
  <h2 class="ds-h">Do / Don't</h2>
  <div class="dd" style="margin-top:4px;">
    <div class="do"><div class="do-h">✓ Do</div><div class="do-b"><ul>
      <li>Use Playfair Display italic only on key emotional words in headings</li>
      <li>Use teal (#00B8F1) as the accent — labels, links, em accents</li>
      <li>Use 50px border-radius on all buttons — pill is a brand signature</li>
      <li>Use DM Sans for all body, UI, and nav copy</li>
      <li>Use Roboto Bold for all h1/h2 structural headings</li>
      <li>Alternate sections: white → cream → navy</li>
      <li>Show phone and location on every surgeon card</li>
      <li>Lead hero with patient outcome, not technology name</li>
      <li>Embed all forms via HubSpot — no native HTML forms</li>
    </ul></div></div>
    <div class="dont"><div class="dont-h">✗ Don't</div><div class="dont-b"><ul>
      <li>Use Playfair Display for full headlines or body text</li>
      <li>Use gold — removed from the system</li>
      <li>Use square or low-radius buttons</li>
      <li>Use more than 3 colors in any single component</li>
      <li>Lead with technology names before patient benefit</li>
      <li>Use font-size below 13px for user-facing text</li>
      <li>Place more than 2 CTAs in the same visual area</li>
      <li>Use obvious stock imagery with studio lighting</li>
    </ul></div></div>
  </div>
</section>

<!-- CSS TOKENS -->
<section class="ds-section" id="tokens">
  <div class="ds-lbl"><div class="ds-lbl-line"></div><span class="ds-lbl-text">Guidelines</span></div>
  <h2 class="ds-h">CSS Tokens</h2>
  <p class="ds-desc">Copy this :root block into any ART interface to inherit the full design system.</p>
  <div class="ds-code">
<span class="kw">:root</span> {
  <span class="com">/* Brand colors */</span>
  <span class="kw">--navy</span>: <span class="val">#14387F</span>;
  <span class="kw">--teal</span>: <span class="val">#00B8F1</span>;
  <span class="kw">--teal-light</span>: <span class="val">#E5F7FE</span>;
  <span class="kw">--white</span>: <span class="val">#FFFFFF</span>;

  <span class="com">/* Neutrals */</span>
  <span class="kw">--cream</span>: <span class="val">#F9F6F0</span>;
  <span class="kw">--text</span>: <span class="val">#1A1A2E</span>;
  <span class="kw">--muted</span>: <span class="val">#6B7B8F</span>;
  <span class="kw">--border</span>: <span class="val">#E8EDF5</span>;

  <span class="com">/* Typography */</span>
  <span class="kw">--font-display</span>: <span class="val">'Playfair Display', serif</span>;  <span class="com">/* Accent words in headings only */</span>
  <span class="kw">--font-body</span>: <span class="val">'DM Sans', sans-serif</span>;          <span class="com">/* All UI, body, nav */</span>
  <span class="com">/* Roboto Bold used directly on h1, h2 — not via variable */</span>
}

<span class="com">/* Google Fonts */</span>
<span class="kw">@import</span> url(<span class="val">'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Roboto:wght@300;400;500;700&family=DM+Sans:wght@300;400;500;600&display=swap'</span>);
  </div>
</section>

</main>
<script>
const sections = document.querySelectorAll('.ds-section');
const navItems = document.querySelectorAll('.ds-nav-item');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navItems.forEach(i => i.classList.remove('active'));
      const a = document.querySelector(`.ds-nav-item[href="#${e.target.id}"]`);
      if (a) a.classList.add('active');
    }
  });
}, { threshold: 0.3 });
sections.forEach(s => obs.observe(s));
</script>
</body>
</html>
