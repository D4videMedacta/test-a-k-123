<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ART Design System</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Roboto:wght@300;400;500;700&family=DM+Sans:wght@300;400;500;600&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root {
  --navy: #14387F;
  --teal: #00B8F1;
  --teal-light: #E5F7FE;
  --white: #FFFFFF;
  --cream: #F9F6F0;
  --text: #1A1A2E;
  --muted: #6B7B8F;
  --border: #E8EDF5;
  --font-display: 'Playfair Display', serif;
  --font-body: 'DM Sans', sans-serif;
  --font-mono: 'Roboto Mono', monospace;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: var(--font-body); background: #f0f2f7; color: var(--text); font-size: 15px; line-height: 1.6; }

.ds-sidebar { position: fixed; top: 0; left: 0; width: 220px; height: 100vh; background: var(--navy); overflow-y: auto; z-index: 100; padding-bottom: 40px; }
.ds-content { margin-left: 220px; min-height: 100vh; }
.ds-sidebar-logo { padding: 24px 20px 16px; border-bottom: 1px solid rgba(255,255,255,.1); }
.ds-sidebar-logo-name { font-family: var(--font-display); font-size: 13px; color: white; font-style: italic; }
.ds-sidebar-logo-sub { font-size: 9px; color: var(--teal); letter-spacing: 2px; text-transform: uppercase; margin-top: 3px; }
.ds-nav-section { padding: 16px 20px 6px; font-size: 9px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,.3); }
.ds-nav-item { display: block; padding: 8px 20px; font-size: 12px; color: rgba(255,255,255,.65); text-decoration: none; transition: all .2s; border-left: 2px solid transparent; font-family: var(--font-body); }
.ds-nav-item:hover, .ds-nav-item.active { color: white; background: rgba(255,255,255,.06); border-left-color: var(--teal); }

.ds-section { padding: 56px 48px; border-bottom: 1px solid var(--border); background: white; }
.ds-section:nth-child(even) { background: var(--cream); }
.ds-lbl { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 12px; }
.ds-lbl-line { width: 28px; height: 2px; background: var(--teal); }
.ds-lbl-text { font-size: 11px; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; color: var(--teal); }
.ds-h { font-family: 'Roboto', sans-serif; font-size: 30px; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
.ds-h em { font-family: var(--font-display); font-style: italic; font-weight: 500; }
.ds-desc { font-size: 14px; color: var(--muted); max-width: 580px; font-weight: 300; line-height: 1.7; margin-top: 4px; margin-bottom: 32px; }
.ds-sublabel { font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; margin-top: 28px; }

.ds-code { background: var(--navy); color: #a8d8ea; font-family: var(--font-mono); font-size: 12px; padding: 20px 24px; border-radius: 14px; overflow-x: auto; margin-top: 24px; line-height: 2; }
.ds-code .kw { color: var(--teal); }
.ds-code .val { color: #ffd580; }
.ds-code .com { color: rgba(168,216,234,.35); }

.g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.g3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
.g4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
.g5 { display: grid; grid-template-columns: repeat(5,1fr); gap: 16px; }

/* Color card */
.cc { border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
.cc-sw { height: 70px; }
.cc-info { padding: 12px; background: white; }
.cc-name { font-size: 13px; font-weight: 600; color: var(--navy); }
.cc-hex { font-family: var(--font-mono); font-size: 11px; color: var(--muted); margin-top: 2px; }
.cc-role { font-size: 11px; color: var(--muted); margin-top: 3px; line-height: 1.4; }
.cc-var { font-family: var(--font-mono); font-size: 10px; color: var(--teal); margin-top: 4px; }

/* Type sample */
.ts { padding: 24px; background: white; border: 1px solid var(--border); border-radius: 14px; margin-bottom: 12px; }
.ds-section:nth-child(even) .ts { background: white; }
.ts-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
.ts-tag { font-family: var(--font-mono); font-size: 10px; color: var(--muted); background: var(--cream); padding: 2px 8px; border-radius: 4px; }

/* Spacing */
.sp-row { display: flex; align-items: center; gap: 16px; padding: 10px 16px; background: white; border: 1px solid var(--border); border-radius: 10px; margin-bottom: 8px; }
.sp-bar { background: var(--teal); height: 18px; border-radius: 3px; opacity: .6; flex-shrink: 0; }

/* Component wrapper */
.cw { border: 1px solid var(--border); border-radius: 16px; overflow: hidden; background: white; }
.cw-pre { padding: 36px 24px; background: var(--cream); display: flex; align-items: center; justify-content: center; min-height: 140px; border-bottom: 1px solid var(--border); flex-wrap: wrap; gap: 16px; }
.cw-pre-dark { background: var(--navy); }
.cw-meta { padding: 16px 20px; }
.cw-name { font-size: 13px; font-weight: 600; color: var(--navy); }
.cw-desc { font-size: 12px; color: var(--muted); margin-top: 4px; line-height: 1.5; }

/* ─── Exact LP components ─────────────────────────────────────────────────── */
.btn-white { background: white; color: var(--navy); border: none; padding: 14px 32px; border-radius: 50px; font-size: 16px; font-weight: 600; cursor: pointer; transition: .25s; text-decoration: none; display: inline-block; letter-spacing: .2px; font-family: var(--font-body); }
.btn-ghost { border: 1px solid rgba(255,255,255,.25); color: white; background: transparent; padding: 14px 32px; border-radius: 50px; font-size: 16px; font-weight: 500; cursor: pointer; transition: .25s; text-decoration: none; display: inline-block; font-family: var(--font-body); }
.nav-pill { background: var(--navy); color: white; border: none; padding: 10px 24px; border-radius: 50px; font-size: 15px; font-weight: 500; cursor: pointer; text-decoration: none; letter-spacing: .3px; display: inline-block; font-family: var(--font-body); }
.nav-pill-teal { background: var(--teal); color: white; border: none; padding: 10px 24px; border-radius: 50px; font-size: 15px; font-weight: 500; cursor: pointer; text-decoration: none; letter-spacing: .3px; display: inline-block; font-family: var(--font-body); }
.surgeon-tag { background: var(--teal-light); color: var(--teal); font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 50px; letter-spacing: .3px; display: inline-block; }
.tag-filter-btn { background: white; border: 1.5px solid var(--border); border-radius: 50px; padding: 7px 16px; font-size: 14px; font-weight: 600; color: var(--muted); cursor: pointer; font-family: var(--font-body); letter-spacing: .3px; }
.tag-filter-btn.on { background: var(--navy); color: white; border-color: var(--navy); }
.surgeon-card { background: white; border-radius: 20px; overflow: hidden; border: 1px solid var(--border); width: 220px; }
.surgeon-photo { height: 180px; background: linear-gradient(135deg,#0d2a63,#1a4a9a); position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }
.surgeon-cert { position: absolute; top: 14px; right: 14px; background: var(--teal); color: white; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; padding: 5px 12px; border-radius: 50px; text-transform: uppercase; }
.surgeon-tags { display: flex; flex-wrap: wrap; gap: 6px; padding: 14px 16px 0; }
.surgeon-info { padding: 14px 16px 16px; }
.surgeon-name { font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 3px; }
.surgeon-spec { font-size: 12px; font-weight: 600; color: var(--teal); letter-spacing: .5px; margin-bottom: 6px; text-transform: uppercase; }
.surgeon-loc { font-size: 13px; color: var(--muted); display: flex; align-items: center; gap: 5px; margin-bottom: 12px; }
.surgeon-btn { width: 100%; background: var(--navy); color: white; border: none; padding: 12px; border-radius: 10px; font-size: 14px; font-weight: 500; cursor: pointer; letter-spacing: .3px; font-family: var(--font-body); }
.cert-card { border-radius: 20px; padding: 36px 28px; border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.06); max-width: 240px; }
.cert-card-icon { width: 52px; height: 52px; border-radius: 14px; background: rgba(0,184,241,.2); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
.cert-card-title { font-family: 'Roboto', sans-serif; font-size: 17px; font-weight: 600; color: white; margin-bottom: 10px; }
.cert-card-text { font-size: 13px; color: rgba(255,255,255,.55); line-height: 1.65; }
.section-label { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 16px; }
.section-label-line { width: 28px; height: 2px; background: var(--teal); }
.section-label-text { font-size: 13px; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; color: var(--teal); }

/* Do/Don't */
.dd { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.do, .dont { border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
.do-h { background: #1D9E75; color: white; padding: 10px 18px; font-size: 12px; font-weight: 700; }
.dont-h { background: #E24B4A; color: white; padding: 10px 18px; font-size: 12px; font-weight: 700; }
.do-b, .dont-b { padding: 20px 24px; font-size: 13px; color: var(--muted); background: white; }
.do-b li, .dont-b li { margin-bottom: 8px; padding-left: 4px; line-height: 1.5; }
.do-b ul, .dont-b ul { padding-left: 18px; }

.back-to-top-demo { width: 48px; height: 48px; border-radius: 50%; background: var(--navy); color: white; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(20,56,127,.25); }

@media (max-width: 900px) {
  .ds-sidebar { width: 100%; height: auto; position: relative; }
  .ds-content { margin-left: 0; }
  .g2, .g3, .g4, .g5, .dd { grid-template-columns: 1fr; }
  .ds-section { padding: 40px 24px; }
}
</style>
</head>
<body>

<nav class="ds-sidebar">
  <div class="ds-sidebar-logo">
    <img src="data:image/svg+xml;base64," alt="The Art of Knee" style="width:140px;height:auto;display:block;margin-bottom:4px;" />
    <div class="ds-sidebar-logo-sub">Design System v1.0</div>
  </div>
  <div class="ds-nav-section">Foundations</div>
  <a href="#colors" class="ds-nav-item">Colors</a>
  <a href="#typography" class="ds-nav-item">Typography</a>
  <a href="#spacing" class="ds-nav-item">Spacing</a>
  <a href="#radius" class="ds-nav-item">Radius & Shadows</a>
  <div class="ds-nav-section">Components</div>
  <a href="#nav-comp" class="ds-nav-item">Navigation</a>
  <a href="#buttons" class="ds-nav-item">Buttons</a>
  <a href="#tags" class="ds-nav-item">Tags & Filters</a>
  <a href="#surgeon-card" class="ds-nav-item">Surgeon Card</a>
  <a href="#cert-card" class="ds-nav-item">Cert Card</a>
  <a href="#section-label" class="ds-nav-item">Section Labels</a>
  <a href="#back-to-top" class="ds-nav-item">Back to Top</a>
  <a href="#logos" class="ds-nav-item">Logos</a>
  <div class="ds-nav-section">Guidelines</div>
  <a href="#imagery" class="ds-nav-item">Imagery</a>
  <a href="#voice" class="ds-nav-item">Voice & Tone</a>
  <a href="#do-dont" class="ds-nav-item">Do / Don't</a>
  <a href="#tokens" class="ds-nav-item">CSS Tokens</a>
</nav>

<main class="ds-content">

<!-- COLORS -->
<section class="ds-section" id="colors">
  <div class="ds-lbl"><div class="ds-lbl-line"></div><span class="ds-lbl-text">Foundations</span></div>
  <h2 class="ds-h">Color System</h2>
  <p class="ds-desc">Navy is the primary brand. Teal is the action and accent color — used for CTAs, labels, links, filter highlights, and the typographic accent on headings. No gold.</p>

  <div class="ds-sublabel" style="margin-top:0;">Brand</div>
  <div class="g3" style="margin-bottom:24px;">
    <div class="cc"><div class="cc-sw" style="background:#14387F;"></div><div class="cc-info"><div class="cc-name">Navy</div><div class="cc-hex">#14387F</div><div class="cc-role">Hero, cert section, nav, buttons</div><div class="cc-var">--navy</div></div></div>
    <div class="cc"><div class="cc-sw" style="background:#00B8F1;"></div><div class="cc-info"><div class="cc-name">Teal</div><div class="cc-hex">#00B8F1</div><div class="cc-role">CTAs, labels, links, em accents</div><div class="cc-var">--teal</div></div></div>
    <div class="cc"><div class="cc-sw" style="background:#E5F7FE;border-bottom:1px solid #E8EDF5;"></div><div class="cc-info"><div class="cc-name">Teal Light</div><div class="cc-hex">#E5F7FE</div><div class="cc-role">Tag backgrounds, info banners</div><div class="cc-var">--teal-light</div></div></div>
  </div>

  <div class="ds-sublabel">Brand Gradient</div>
  <div style="margin-bottom:24px;">
    <div style="border-radius:14px;overflow:hidden;border:1px solid var(--border);display:inline-block;min-width:300px;">
      <div style="height:70px;background:linear-gradient(90deg,#14387F 0%,#00B8F1 100%);"></div>
      <div style="padding:12px;background:white;">
        <div style="font-size:13px;font-weight:600;color:var(--navy);">Navy → Teal Gradient</div>
        <div style="font-family:var(--font-mono);font-size:11px;color:var(--muted);margin-top:2px;">linear-gradient(90deg, #14387F 0%, #00B8F1 100%)</div>
        <div style="font-size:11px;color:var(--muted);margin-top:3px;">Used on brand gradient logo, hero accents</div>
      </div>
    </div>
    <div style="border-radius:14px;overflow:hidden;border:1px solid var(--border);display:inline-block;min-width:300px;margin-left:16px;">
      <div style="height:70px;background:linear-gradient(135deg,#0d2a63 0%,#14387F 50%,#1a4a9a 100%);"></div>
      <div style="padding:12px;background:white;">
        <div style="font-size:13px;font-weight:600;color:var(--navy);">Navy Depth Gradient</div>
        <div style="font-family:var(--font-mono);font-size:11px;color:var(--muted);margin-top:2px;">linear-gradient(135deg, #0d2a63 0%, --navy 50%, #1a4a9a 100%)</div>
        <div style="font-size:11px;color:var(--muted);margin-top:3px;">Hero section, cert section backgrounds</div>
      </div>
    </div>
  </div>

  <div class="ds-sublabel">Neutrals</div>
  <div class="g5">
    <div class="cc"><div class="cc-sw" style="background:#F9F6F0;border-bottom:1px solid #E8EDF5;"></div><div class="cc-info"><div class="cc-name">Cream</div><div class="cc-hex">#F9F6F0</div><div class="cc-role">Alternating sections</div><div class="cc-var">--cream</div></div></div>
    <div class="cc"><div class="cc-sw" style="background:#E8EDF5;"></div><div class="cc-info"><div class="cc-name">Border</div><div class="cc-hex">#E8EDF5</div><div class="cc-role">Cards, dividers, inputs</div><div class="cc-var">--border</div></div></div>
    <div class="cc"><div class="cc-sw" style="background:#6B7B8F;"></div><div class="cc-info"><div class="cc-name">Muted</div><div class="cc-hex">#6B7B8F</div><div class="cc-role">Secondary text, captions</div><div class="cc-var">--muted</div></div></div>
    <div class="cc"><div class="cc-sw" style="background:#1A1A2E;"></div><div class="cc-info"><div class="cc-name">Text</div><div class="cc-hex">#1A1A2E</div><div class="cc-role">Body text, headings</div><div class="cc-var">--text</div></div></div>
    <div class="cc"><div class="cc-sw" style="background:#fff;border-bottom:1px solid #E8EDF5;"></div><div class="cc-info"><div class="cc-name">White</div><div class="cc-hex">#FFFFFF</div><div class="cc-role">Cards, nav, form boxes</div><div class="cc-var">--white</div></div></div>
  </div>
</section>

<!-- TYPOGRAPHY -->
<section class="ds-section" id="typography">
  <div class="ds-lbl"><div class="ds-lbl-line"></div><span class="ds-lbl-text">Foundations</span></div>
  <h2 class="ds-h">Typography</h2>
  <p class="ds-desc">Three typefaces. Roboto Bold for structural h1/h2. DM Sans for all body, UI, nav. Playfair Display italic only for emotional accent words inside headings — never for full sentences.</p>

  <div class="ts">
    <div style="font-family:'Roboto',sans-serif;font-size:clamp(40px,5.5vw,64px);font-weight:700;line-height:1.05;color:white;background:linear-gradient(135deg,#0d2a63,#1a4a9a);padding:28px;border-radius:10px;">The art of <span style="font-family:'Playfair Display',serif;font-style:italic;color:#00B8F1;">restoring</span><br>your knee.</div>
    <div class="ts-meta"><span class="ts-tag">Roboto Bold — hero-h1</span><span class="ts-tag">clamp(44px, 5.5vw, 72px)</span><span class="ts-tag">Playfair Display italic on accent word</span></div>
  </div>

  <div class="ts">
    <div style="font-family:'Roboto',sans-serif;font-size:clamp(30px,4vw,48px);font-weight:700;color:var(--navy);line-height:1.1;">What patients are <span style="font-family:'Playfair Display',serif;font-style:italic;color:#00B8F1;">saying.</span></div>
    <div class="ts-meta"><span class="ts-tag">Roboto Bold — section-h2</span><span class="ts-tag">clamp(32px, 4vw, 52px)</span></div>
  </div>

  <div class="ts">
    <div style="font-family:'DM Sans',sans-serif;font-size:18px;line-height:1.8;color:var(--muted);font-weight:300;max-width:520px;">Connecting patients with board-certified surgeons trained in the ART protocol — delivering personalized, minimally invasive knee care designed around you.</div>
    <div class="ts-meta"><span class="ts-tag">DM Sans Light 300 — section-p</span><span class="ts-tag">18px / line-height 1.8</span><span class="ts-tag">color: --muted</span></div>
  </div>

  <div class="ts">
    <div style="font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;letter-spacing:2.5px;text-transform:uppercase;color:var(--teal);">ART Certification Program</div>
    <div class="ts-meta"><span class="ts-tag">DM Sans SemiBold 600 — section-label-text</span><span class="ts-tag">13px / letter-spacing 2.5px / uppercase</span></div>
  </div>

  <div class="ts">
    <div style="font-family:'DM Sans',sans-serif;font-size:15px;font-weight:500;color:var(--text);">Surgeons · Resources · Stories · Certification · Get In Touch</div>
    <div class="ts-meta"><span class="ts-tag">DM Sans Medium 500 — nav-links</span><span class="ts-tag">14–15px</span></div>
  </div>

  <div class="ts">
    <div style="font-family:'Playfair Display',serif;font-style:italic;font-size:17px;color:var(--navy);line-height:1.65;">"I was back on the golf course in 8 weeks. My surgeon explained every step — I never felt like just a number."</div>
    <div class="ts-meta"><span class="ts-tag">Playfair Display Italic — testimonial quote</span><span class="ts-tag">16–18px</span></div>
  </div>

  <div class="ts">
    <div style="font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--navy);">Dr. Keith Berend</div>
    <div class="ts-meta"><span class="ts-tag">Playfair Display Bold — surgeon-name on card</span><span class="ts-tag">18–20px</span></div>
  </div>

  <div class="ts">
    <div style="font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;letter-spacing:.5px;color:var(--teal);text-transform:uppercase;">Orthopedic Surgery · Subvastus Approach</div>
    <div class="ts-meta"><span class="ts-tag">DM Sans SemiBold — surgeon-spec / tag text</span><span class="ts-tag">11–13px / uppercase</span></div>
  </div>
</section>

<!-- SPACING -->
<section class="ds-section" id="spacing">
  <div class="ds-lbl"><div class="ds-lbl-line"></div><span class="ds-lbl-text">Foundations</span></div>
  <h2 class="ds-h">Spacing Scale</h2>
  <p class="ds-desc">Base-8 scale. Generous spacing aids legibility for the 55+ audience. Sections use 80–120px vertical padding.</p>
  <div class="sp-row"><div class="sp-bar" style="width:4px;"></div><div><div style="font-size:13px;font-weight:600;color:var(--navy);">4px — tag gaps, icon spacing</div></div></div>
  <div class="sp-row"><div class="sp-bar" style="width:8px;"></div><div><div style="font-size:13px;font-weight:600;color:var(--navy);">8px — compact inner padding</div></div></div>
  <div class="sp-row"><div class="sp-bar" style="width:12px;"></div><div><div style="font-size:13px;font-weight:600;color:var(--navy);">12px — surgeon-btn padding, surgeon-info bottom</div></div></div>
  <div class="sp-row"><div class="sp-bar" style="width:16px;"></div><div><div style="font-size:13px;font-weight:600;color:var(--navy);">16px — card inner padding, grid gap small</div></div></div>
  <div class="sp-row"><div class="sp-bar" style="width:20px;"></div><div><div style="font-size:13px;font-weight:600;color:var(--navy);">20px — section-label margin-bottom</div></div></div>
  <div class="sp-row"><div class="sp-bar" style="width:24px;"></div><div><div style="font-size:13px;font-weight:600;color:var(--navy);">24px — nav height, gap large</div></div></div>
  <div class="sp-row"><div class="sp-bar" style="width:32px;"></div><div><div style="font-size:13px;font-weight:600;color:var(--navy);">32px — button padding horizontal, card padding</div></div></div>
