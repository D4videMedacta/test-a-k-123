      <div><strong>Hidcote Manor Garden (NT)</strong> — sab 6 giugno · nationaltrust.org.uk/hidcote</div>
    </div>
  </div>

</div>

<script>
// ── COORDINATE TAPPE ──
const stops = [
  // Giorno 1
  { day: 1, name: "London Gatwick Airport", lat: 51.1537, lng: -0.1821, time: "08:30", icon: "✈" },
  { day: 1, name: "Stonehenge", lat: 51.1789, lng: -1.8262, time: "10:30", icon: "◎" },
  { day: 1, name: "Lacock", lat: 51.4158, lng: -2.1231, time: "14:00", icon: "⌂" },
  { day: 1, name: "Bibury — Arlington Row", lat: 51.7585, lng: -1.8344, time: "16:30", icon: "◉" },
  { day: 1, name: "Cheltenham (base)", lat: 51.9000, lng: -2.0724, time: "18:30", icon: "🏠" },
  // Giorno 2
  { day: 2, name: "Cheltenham (partenza)", lat: 51.9000, lng: -2.0724, time: "07:00", icon: "🏠" },
  { day: 2, name: "Bath — Royal Crescent", lat: 51.3866, lng: -2.3671, time: "07:15", icon: "◉" },
  { day: 2, name: "Roman Baths", lat: 51.3811, lng: -2.3596, time: "09:00", icon: "⊛" },
  { day: 2, name: "Prior Park Garden", lat: 51.3658, lng: -2.3457, time: "11:30", icon: "⬡" },
  { day: 2, name: "Burford", lat: 51.8071, lng: -1.6368, time: "13:30", icon: "⌂" },
  { day: 2, name: "Lower Slaughter", lat: 51.8999, lng: -1.7645, time: "15:30", icon: "◉" },
  { day: 2, name: "The Royal Oak, Whatcote ⭐", lat: 52.0992, lng: -1.5633, time: "19:00", icon: "★" },
  // Giorno 3
  { day: 3, name: "Cheltenham (partenza)", lat: 51.9002, lng: -2.0720, time: "06:30", icon: "🏠" },
  { day: 3, name: "Broadway Tower + Bunker", lat: 52.0243, lng: -1.8357, time: "06:45", icon: "◎" },
  { day: 3, name: "Chipping Campden", lat: 52.0508, lng: -1.7808, time: "11:00", icon: "⌂" },
  { day: 3, name: "Hidcote Manor Garden", lat: 52.0830, lng: -1.7456, time: "12:30", icon: "⬡" },
  { day: 3, name: "Ebrington Arms", lat: 52.0663, lng: -1.7299, time: "14:30", icon: "☕" },
  { day: 3, name: "Stanton", lat: 52.0068, lng: -1.9019, time: "16:30", icon: "◉" },
  // Giorno 4
  { day: 4, name: "Cheltenham (partenza)", lat: 51.9001, lng: -2.0722, time: "07:30", icon: "🏠" },
  { day: 4, name: "Coln St Aldwyns", lat: 51.7459, lng: -1.7914, time: "08:00", icon: "◎" },
  { day: 4, name: "Winchcombe", lat: 51.9572, lng: -1.9692, time: "10:00", icon: "⌂" },
  { day: 4, name: "London Gatwick Airport", lat: 51.1537, lng: -0.1822, time: "15:30", icon: "✈" },
];

const dayColors = { 1: "#2A6EBB", 2: "#3A8A3A", 3: "#C47A2A", 4: "#7A3A8A" };
const dayRoutes = {
  1: [[51.1537,-0.1821],[51.1789,-1.8262],[51.4158,-2.1231],[51.7585,-1.8344],[51.9000,-2.0724]],
  2: [[51.9000,-2.0724],[51.3866,-2.3671],[51.3811,-2.3596],[51.3658,-2.3457],[51.8071,-1.6368],[51.8999,-1.7645],[52.0992,-1.5633]],
  3: [[51.9002,-2.0720],[52.0243,-1.8357],[52.0508,-1.7808],[52.0830,-1.7456],[52.0663,-1.7299],[52.0068,-1.9019]],
  4: [[51.9001,-2.0722],[51.7459,-1.7914],[51.9572,-1.9692],[51.1537,-0.1822]],
};

let map, allMarkers = [], allPolylines = [];

function makeSvgIcon(color, emoji, size) {
  const s = size || 32;
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${s}" height="${s+8}" viewBox="0 0 ${s} ${s+8}">
    <circle cx="${s/2}" cy="${s/2}" r="${s/2-2}" fill="${color}" stroke="white" stroke-width="2.5"/>
    <text x="${s/2}" y="${s/2+4}" text-anchor="middle" font-size="12" fill="white">${emoji}</text>
    <polygon points="${s/2-5},${s-2} ${s/2+5},${s-2} ${s/2},${s+6}" fill="${color}"/>
  </svg>`;
  return L.divIcon({
    html: svg, className: '', iconSize: [s, s+8],
    iconAnchor: [s/2, s+6], popupAnchor: [0, -(s+6)]
  });
}

window.onload = function() {
  map = L.map('map', { zoomControl: true, scrollWheelZoom: false });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors © <a href="https://carto.com/">CARTO</a>',
    maxZoom: 19
  }).addTo(map);

  // Draw all routes and markers
  stops.forEach(function(s) {
    const color = dayColors[s.day];
    const marker = L.marker([s.lat, s.lng], { icon: makeSvgIcon(color, s.icon) })
      .bindPopup(`<div style="font-family:DM Sans,sans-serif;min-width:160px">
        <div style="font-weight:600;font-size:13px;margin-bottom:3px">${s.name}</div>
        <div style="font-size:11px;color:#888">Giorno ${s.day} · ${s.time}</div>
      </div>`)
      .addTo(map);
    marker._day = s.day;
    allMarkers.push(marker);
  });

  Object.keys(dayRoutes).forEach(function(d) {
    const poly = L.polyline(dayRoutes[d], {
      color: dayColors[d], weight: 3, opacity: 0.75,
      dashArray: d == 4 ? '8,6' : null
    }).addTo(map);
    poly._day = parseInt(d);
    allPolylines.push(poly);
  });

  fitAll();
};

function fitAll() {
  const allCoords = stops.map(s => [s.lat, s.lng]);
  map.fitBounds(L.latLngBounds(allCoords).pad(0.08));
}

function filterDay(day, btn) {
  document.querySelectorAll('.map-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  if (day === 0) {
    allMarkers.forEach(m => { m.setOpacity(1); map.addLayer(m); });
    allPolylines.forEach(p => { p.setStyle({ opacity: 0.75 }); map.addLayer(p); });
    fitAll();
    return;
  }

  const dayCoords = [];
  allMarkers.forEach(function(m) {
    if (m._day === day) { m.setOpacity(1); map.addLayer(m); dayCoords.push(m.getLatLng()); }
    else { m.setOpacity(0.15); }
  });
  allPolylines.forEach(function(p) {
    if (p._day === day) { p.setStyle({ opacity: 0.9, weight: 4 }); }
    else { p.setStyle({ opacity: 0.1 }); }
  });

  if (dayCoords.length) {
    map.fitBounds(L.latLngBounds(dayCoords).pad(0.12));
  }
}
</script>
</body>
